#!/usr/bin/env bash
# SPDX-License-Identifier: BSD-3-Clause
# noti-bash installer — fzf-style.
#
# What it does:
#   1. Appends a managed block to your shell rc (~/.bashrc or ~/.zshrc,
#      auto-detected) bracketed by:
#          # >>> noti-bash >>>
#          export PATH="<repo>/bin:$PATH"
#          export NOTI_WEBHOOK="..."     # optional
#          # <<< noti-bash <<<
#   2. Optionally symlinks skills/noti into ~/.claude/skills/noti so
#      Claude Code picks up the natural-language trigger skill.
#   3. Optionally prompts for a Discord/Slack webhook URL and writes it
#      into the same block. Skipping the prompt prints short manual
#      instructions and points at README.md's "Webhook 발급받기".
#   4. Idempotent — re-running replaces the managed block with the
#      desired content (no duplicates).
#
# Usage:
#   ./install                       # interactive
#   ./install --all                 # non-interactive: PATH + skill (no webhook)
#   ./install --no-skill            # PATH only, no skill prompt
#   ./install --no-webhook          # skip webhook prompt entirely
#   ./install --webhook URL         # set webhook non-interactively
#   ./install --rc PATH             # use this rc file (skip auto-detect)
#   ./install --uninstall           # remove the managed block and skill symlink
#   ./install -h | --help

set -Eeuo pipefail

REPO_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
BIN_DIR="$REPO_DIR/bin"
README_ANCHOR="$REPO_DIR/README.md#webhook-발급받기"

BEGIN_MARKER='# >>> noti-bash >>>'
END_MARKER='# <<< noti-bash <<<'
LEGACY_MARKER='# noti-bash'   # earlier installs used a single marker

SKILL_LINK="$HOME/.claude/skills/noti"

INSTALL_SKILL="ask"     # ask | yes | no
INSTALL_WEBHOOK="ask"   # ask | yes | no
WEBHOOK_URL=""
SHELL_RC=""
MODE="install"          # install | uninstall

log() { printf '[noti-bash] %s\n' "$*"; }
err() { printf '[noti-bash] %s\n' "$*" >&2; }

usage() {
  sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//' | head -32
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --all)        INSTALL_SKILL=yes;   INSTALL_WEBHOOK=no; shift ;;
    --no-skill)   INSTALL_SKILL=no;    shift ;;
    --no-webhook) INSTALL_WEBHOOK=no;  shift ;;
    --webhook)    INSTALL_WEBHOOK=yes; WEBHOOK_URL="${2:?--webhook needs a URL}"; shift 2 ;;
    --rc)         SHELL_RC="${2:?--rc needs a path}"; shift 2 ;;
    --uninstall)  MODE=uninstall;      shift ;;
    -h|--help)    usage; exit 0 ;;
    *)            err "unknown arg: $1"; usage >&2; exit 1 ;;
  esac
done

detect_rc() {
  case "${SHELL:-}" in
    */zsh)  echo "$HOME/.zshrc" ;;
    */bash) echo "$HOME/.bashrc" ;;
    *)      echo "$HOME/.bashrc" ;;
  esac
}
[[ -z "$SHELL_RC" ]] && SHELL_RC="$(detect_rc)"

mask_webhook() {
  # Print a masked version of a webhook URL for confirmation messages.
  printf '%s' "$1" | sed -E \
    -e 's#(/api/webhooks/[^/]+/)[A-Za-z0-9_-]+#\1***#g' \
    -e 's#(/services/[^/]+/[^/]+/)[A-Za-z0-9_-]+#\1***#g'
}

validate_webhook() {
  case "$1" in
    https://discord.com/api/webhooks/*|\
    https://discordapp.com/api/webhooks/*|\
    https://ptb.discord.com/api/webhooks/*|\
    https://canary.discord.com/api/webhooks/*|\
    https://hooks.slack.com/services/*) return 0 ;;
    *) return 1 ;;
  esac
}

ensure_bin_symlink() {
  mkdir -p "$BIN_DIR"
  if [[ ! -e "$BIN_DIR/noti" && ! -L "$BIN_DIR/noti" ]]; then
    ln -s ../noti "$BIN_DIR/noti"
    log "Created $BIN_DIR/noti -> ../noti"
  fi
}

remove_block() {
  [[ -f "$SHELL_RC" ]] || return 0
  local tmp; tmp="$(mktemp)"
  # 1) Remove modern bracketed block.
  awk -v b="$BEGIN_MARKER" -v e="$END_MARKER" '
    $0 == b { skip = 1; next }
    skip && $0 == e { skip = 0; next }
    skip { next }
    { print }
  ' "$SHELL_RC" > "$tmp"
  # 2) Remove legacy single-marker block (marker line + following export line).
  awk -v m="$LEGACY_MARKER" '
    BEGIN { skip = 0 }
    $0 == m { skip = 1; next }
    skip && $0 ~ /^export (PATH|NOTI_WEBHOOK)=/ { skip = 0; next }
    skip { skip = 0 }
    { print }
  ' "$tmp" > "$SHELL_RC"
  # 3) Collapse runs of blank lines that may have been left behind.
  awk 'BEGIN{p=0} { if ($0=="") { if (p) next; p=1 } else p=0; print }' "$SHELL_RC" > "$tmp"
  mv "$tmp" "$SHELL_RC"
}

build_block() {
  printf '%s\n' "$BEGIN_MARKER"
  printf 'export PATH="%s:$PATH"\n' "$BIN_DIR"
  if [[ -n "$WEBHOOK_URL" ]]; then
    printf 'export NOTI_WEBHOOK="%s"\n' "$WEBHOOK_URL"
  fi
  printf '%s\n' "$END_MARKER"
}

write_block() {
  touch "$SHELL_RC"
  local desired existing
  desired="$(build_block)"
  existing="$(awk -v b="$BEGIN_MARKER" -v e="$END_MARKER" '
    $0 == b { capture = 1 }
    capture { print }
    $0 == e && capture { exit }
  ' "$SHELL_RC")"

  if [[ -n "$existing" && "$existing" == "$desired" ]]; then
    log "noti-bash block in $SHELL_RC is already up to date."
    return
  fi

  remove_block
  printf '\n%s\n' "$desired" >> "$SHELL_RC"
  if [[ -n "$WEBHOOK_URL" ]]; then
    log "Wrote noti-bash block (PATH + NOTI_WEBHOOK) to $SHELL_RC"
    log "  webhook: $(mask_webhook "$WEBHOOK_URL")"
  else
    log "Wrote noti-bash block (PATH only) to $SHELL_RC"
  fi
}

print_manual_webhook_instructions() {
  cat <<EOF

[noti-bash] To set the webhook later, append one line to $SHELL_RC
            (inside the noti-bash block, or anywhere) and reload:

    export NOTI_WEBHOOK="<your-webhook-url>"

[noti-bash] How to obtain a Discord/Slack webhook URL:
            see README.md → "Webhook 발급받기"
            ($README_ANCHOR)

EOF
}

prompt_webhook() {
  # Already in env? Don't overwrite unless the user explicitly asks.
  if [[ -n "${NOTI_WEBHOOK:-}" ]]; then
    log "NOTI_WEBHOOK is already set in the current environment — skipping prompt."
    log "  (current: $(mask_webhook "$NOTI_WEBHOOK"))"
    return
  fi
  # Already declared in rc? Skip too.
  if [[ -f "$SHELL_RC" ]] && grep -qE '^export NOTI_WEBHOOK=' "$SHELL_RC"; then
    log "NOTI_WEBHOOK already declared in $SHELL_RC — skipping prompt."
    return
  fi

  echo
  log "Optionally register your Discord/Slack webhook URL now."
  log "It will be appended to $SHELL_RC inside the noti-bash block."
  printf '[noti-bash] Paste webhook URL (leave blank to skip): '
  local url
  # -s for silent input — the URL is a credential.
  read -r -s url || url=""
  echo

  if [[ -z "$url" ]]; then
    print_manual_webhook_instructions
    return
  fi

  if ! validate_webhook "$url"; then
    err "URL does not match a Discord or Slack incoming-webhook pattern. Skipping."
    print_manual_webhook_instructions
    return
  fi

  WEBHOOK_URL="$url"
  log "Webhook accepted: $(mask_webhook "$WEBHOOK_URL")"
}

install_skill() {
  mkdir -p "$(dirname "$SKILL_LINK")"
  if [[ -L "$SKILL_LINK" || -e "$SKILL_LINK" ]]; then
    local cur
    cur="$(readlink -f "$SKILL_LINK" 2>/dev/null || true)"
    if [[ "$cur" == "$REPO_DIR/skills/noti" ]]; then
      log "Skill already linked: $SKILL_LINK -> $REPO_DIR/skills/noti"
    else
      log "$SKILL_LINK already exists (resolves to $cur) — leaving it alone."
    fi
    return
  fi
  ln -s "$REPO_DIR/skills/noti" "$SKILL_LINK"
  log "Linked $SKILL_LINK -> $REPO_DIR/skills/noti"
}

remove_skill() {
  if [[ -L "$SKILL_LINK" ]]; then
    rm -f "$SKILL_LINK"
    log "Removed $SKILL_LINK"
  elif [[ -e "$SKILL_LINK" ]]; then
    log "$SKILL_LINK is not a symlink — leaving it alone."
  else
    log "No skill symlink at $SKILL_LINK."
  fi
}

prompt_skill() {
  printf '[noti-bash] Install Claude Code skill (%s)? [Y/n] ' "$SKILL_LINK"
  local ans
  read -r ans || ans=""
  case "${ans,,}" in
    ""|y|yes) INSTALL_SKILL=yes ;;
    *)        INSTALL_SKILL=no  ;;
  esac
}

case "$MODE" in
  install)
    ensure_bin_symlink

    # Skill prompt
    if [[ "$INSTALL_SKILL" == "ask" ]]; then
      if [[ -t 0 ]]; then prompt_skill; else INSTALL_SKILL=no; fi
    fi

    # Webhook prompt — runs before write_block so the URL can be folded in
    if [[ "$INSTALL_WEBHOOK" == "ask" ]]; then
      if [[ -t 0 ]]; then prompt_webhook; else INSTALL_WEBHOOK=no; fi
    elif [[ "$INSTALL_WEBHOOK" == "yes" ]]; then
      if ! validate_webhook "$WEBHOOK_URL"; then
        err "--webhook value does not look like a Discord/Slack URL. Aborting."
        exit 1
      fi
    fi

    write_block

    if [[ "$INSTALL_SKILL" == "yes" ]]; then
      install_skill
    else
      log "Skipped skill install."
    fi

    if [[ "$INSTALL_WEBHOOK" == "no" && -z "$WEBHOOK_URL" ]]; then
      print_manual_webhook_instructions
    fi

    echo
    log "Done. Open a new shell, or run:  source $SHELL_RC"
    log "Then:  noti help"
    ;;

  uninstall)
    remove_block
    remove_skill
    echo
    log "Uninstalled. Repo dir ($REPO_DIR) is untouched — delete it manually if you no longer need it."
    ;;
esac
